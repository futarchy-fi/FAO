{
  "name": "futarchy-fi-fao-e2e",
  "version": "0.0.1",
  "private": true,
  "description": "E2E test harness for the FAO testnet site (site-testnet/) \u2014 runs Playwright against the live deploy + a forked Anvil node. Solidity tests are NOT here \u2014 see foundry.toml + test/.",
  "scripts": {
    "dev": "cd site-testnet && python3 -m http.server 8766",
    "dashboard": "cd audit && python3 -m http.server 8767",
    "dev:anvil": "anvil --fork-url $SEPOLIA_RPC --port 8545",
    "build:sync": "bash scripts/validate-deployments.sh && bash scripts/check-deployments-sync.sh",
    "test": "forge test --no-match-path 'test/fork/*'",
    "test:fork": "forge test --match-path 'test/fork/*'",
    "test:invariant": "forge test --match-test 'invariant_'",
    "test:symbolic": "FOUNDRY_PROFILE=halmos halmos --match-test 'check_INV_'",
    "e2e": "playwright test",
    "e2e:read-only": "playwright test --project=read-only",
    "e2e:headed": "playwright test --headed",
    "e2e:ui": "playwright test --ui",
    "e2e:report": "playwright show-report",
    "capture:screenshots": "bash scripts/capture-screenshots.sh",
    "a11y": "playwright test tests-e2e/journeys/a11y.read-only.spec.ts",
    "lighthouse": "lhci autorun",
    "pages:freshness": "node scripts/check-pages-freshness.mjs",
    "web-vitals:inp": "node scripts/check-inp.mjs",
    "lighthouse:reports": "node scripts/lighthouse-summary.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@synthetixio/synpress": "^4.0.0",
    "typescript": "^5.3.3",
    "viem": "^2.21.0",
    "@axe-core/playwright": "^4.10.0"
  }
}
